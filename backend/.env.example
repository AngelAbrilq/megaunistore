# -------------------------------------------------------
# Archivo de ejemplo de variables de entorno
# Copia este archivo como .env y ajusta los valores
# NUNCA subas el archivo .env real al repositorio
# -------------------------------------------------------

APP_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=mega_uni_store
DB_USER=root
DB_PASSWORD=

# Clave para ejecutar el setup inicial (roles y permisos base)
# Accede a: index.php?route=setup&key=TU_CLAVE_AQUI
# Cambia este valor por algo seguro y elimina la ruta en produccion
SETUP_KEY=
